# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# CMS overrides (local test data, deploy-specific)
/.cms-overrides/
# Editor sessions + uploaded media (not source of truth)
/.editor-sessions/
/public/uploads/
# Merch orders
/.merch-orders/
/dev-*.log
/.cms-overrides/ai-chats/
/.cms-overrides/media/
/.cms-overrides/order-uploads/
/.server.log
