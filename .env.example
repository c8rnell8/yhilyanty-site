# Copy to .env.local (dev) or .env.production (server) and fill in.

# Public base url of the site, no trailing slash.
SITE_URL=http://localhost:3000

# Discord OAuth app (https://discord.com/developers/applications).
# The redirect URI <SITE_URL>/api/auth/callback must be whitelisted in the app.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord user id that gets the /admin panel.
OWNER_DISCORD_ID=

# Signs the session cookie so it can't be forged. Any long random string
# (openssl rand -hex 32). Falls back to DISCORD_CLIENT_SECRET if unset.
SESSION_SECRET=

# Shared secret with yhilbot for the /webedit flow. Must equal the bot's
# WEB_EDITOR_TOKEN.
YHILBOT_API_TOKEN=

# Where CMS data and editor sessions are written.
CMS_DIR=.cms-overrides
EDITOR_SESSIONS_DIR=.editor-sessions

# hCaptcha for the merch order form. Leave unset to use hCaptcha's public
# test keys (always pass - dev only!).
HCAPTCHA_SECRET=
NEXT_PUBLIC_HCAPTCHA_SITEKEY=

# Google Gemini - powers the admin AI assistant. Free key at
# https://aistudio.google.com/apikey.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
